# =============================================================================
# RaspyBank — Modelo de variáveis de ambiente
# =============================================================================
# ESTE arquivo é versionado no Git. Ele documenta quais variáveis existem.
#
# O arquivo real chama-se ".env", fica na RAIZ do repositório e NUNCA é
# versionado — está no .gitignore.
#
# Para começar:
#     cp .env.example .env
#     # depois edite o .env com valores reais
#
# REGRA INVIOLÁVEL: nenhum valor real entra neste arquivo. Nem "só para testar",
# nem "é só a senha local". O push protection do GitHub não reconhece senha de
# Postgres — ele identifica tokens de provedores conhecidos. A proteção contra
# esse vazamento é disciplina, não ferramenta.
# =============================================================================

# -----------------------------------------------------------------------------
# Banco de dados — usuário PROPRIETÁRIO
# -----------------------------------------------------------------------------
# Usado pelas migrações do Flyway. Cria e altera tabelas.
POSTGRES_DB=raspybank
POSTGRES_USER=raspybank_owner
POSTGRES_PASSWORD=troque-esta-senha

# -----------------------------------------------------------------------------
# Banco de dados — usuário de APLICAÇÃO
# -----------------------------------------------------------------------------
# Usado pelo backend em execução. Apenas leitura e escrita de dados.
# Sujeito a Row Level Security — este é o ponto principal da separação.
APP_DB_USER=raspybank_app
APP_DB_PASSWORD=troque-esta-senha-tambem

# -----------------------------------------------------------------------------
# Porta publicada em desenvolvimento
# -----------------------------------------------------------------------------
# Só vale para a VM, e só no loopback (127.0.0.1).
# Altere se a 5432 já estiver ocupada por outra coisa.
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# Fuso horário dos containers
# -----------------------------------------------------------------------------
# O banco armazena timestamps em UTC — decisão de arquitetura.
# Isto afeta apenas a exibição em logs e ferramentas.
TZ=America/Sao_Paulo
